# import-linter — the layering kill-criterion (META-APE spec §3).
# Enforces the target DAG: imports only ever point DOWN.
#   chainaios (Bandit AIOS) > sccc > corcc > accc (cognition) > chaincompiler (compiler-compiler) > prompt_engineering (APE base)
# The *CC are MADE FROM chaincompiler (they import it); chaincompiler imports only APE and NEVER the *CC.
# The AIOS app (construct_language / GBA / HBA / COG) lives in `chainaios`, ABOVE the *CC.

[importlinter]
root_packages =
    chainaios
    sccc
    corcc
    accc
    chaincompiler
    prompt_engineering

[importlinter:contract:down-only]
name = Ecosystem DOWN-only (CC is the BASE; the *CC are made FROM CC; AIOS on top)
type = layers
layers =
    chainaios
    sccc
    corcc
    accc
    chaincompiler
    prompt_engineering
